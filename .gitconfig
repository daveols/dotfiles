[user]
	name = daveols
	email = 10344370+daveols@users.noreply.github.com
[merge]
    # include summaries of merged commits in newly created merge commit messages
    log = true
[diff]
    # detect copies as well as renames
    renames = copies
[pull]
	ff = only
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[include]
	# Machine-specific config (signing keys etc.) — not tracked in dotfiles.
	# See README for the expected contents per machine.
	path = ~/.gitconfig.local
